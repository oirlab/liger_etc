# Starting from: https://github.com/Keck-DataReductionPipelines/KPF-Pipeline/blob/master/.gitignore
# Universal ignore
outputs/*
*.npy
*~
*.DS_Store
.idea/
logs/
receipts/
__pycache__/
*.py[cod]
*$py.class
*.ipynb_checkpoints
*.log

# C extensions
*.so

# Specific .c files (this allows for manual C files to be kept if needed)
hispecdrp/primitives/ramp_fitting/fitramp_cython_Brandt.c


# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg


# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Local / optional example scripts (not tracked)
examples/

# Local simulation I/O (ramp, rate map, Stage 0 products from simulate_up_the_ramp, etc.)
test_data/

# Unit test outputs (e.g. saved Plotly previews from stellar RV tests)
tests/output/

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/
docs/html
docs/doctrees
**/api/generated/**

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# dotenv
.env

# virtualenv
.venv
venv/
ENV/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/

# IDE related settings
.vscode
.cursor/

.pytest_cache

# Version control is autogenerated
hispecdrp/_version.py

# Skip big fits files in demo directory
tests/demo_frames/*.fits
